---
interface Props {
  href: string;
  variant?: 'primary' | 'ghost';
}
const { href, variant = 'ghost' } = Astro.props;
---

<a href={href} class={`button button-${variant}`}>
  <slot />
</a>

<style>
  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 1rem;
    padding: 12px 24px;
    border-radius: 8px;
    transition: filter var(--transition-fast), border-color var(--transition-fast);
  }

  .button-primary {
    background: var(--moonglow);
    color: var(--surface-space);
  }

  .button-primary:hover {
    filter: brightness(1.1);
  }

  .button-ghost {
    background: transparent;
    border: 1px solid var(--border-hairline);
    color: var(--text-moonlight);
  }

  .button-ghost:hover {
    border-color: var(--moonglow-dim);
  }
</style>
