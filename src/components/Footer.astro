---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <a href="/" class="wordmark">moo<span class="wordmark-moon">o</span>nman</a>

    <p class="body-sm footer-signoff">Want to talk about any of this? Get in touch.</p>

    <nav class="footer-links" aria-label="Contact">
      <a href="mailto:alexmooney@hotmail.co.uk" class="body-sm footer-link">Email</a>
      <a href="https://github.com/Moon-Alpha32" class="body-sm footer-link">GitHub</a>
    </nav>

    <p class="label-mono footer-print">© {year} mooonman. Built with Astro.</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--surface-raised);
    border-top: 3px solid var(--navy);
    padding-block: var(--space-lg);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-sm);
  }

  .wordmark {
    font-family: var(--font-display);
    text-transform: uppercase;
    font-size: 1.2rem;
    color: var(--ink);
  }

  .wordmark-moon {
    color: var(--spot-red);
  }

  .footer-signoff {
    color: var(--ink-mute);
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .footer-link {
    color: var(--navy);
    text-decoration: underline;
    transition: color var(--transition-fast);
  }

  .footer-link:hover {
    color: var(--spot-red);
  }

  .footer-print {
    color: var(--ink-mute);
    font-weight: 400;
  }
</style>
