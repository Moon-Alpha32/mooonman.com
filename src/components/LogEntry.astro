---
interface Props {
  date: Date;
}
const { date } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(date);
---

<article class="log-entry">
  <p class="label-mono log-entry-date">{formattedDate}</p>
  <div class="body-sm log-entry-body">
    <slot />
  </div>
</article>

<style>
  .log-entry {
    padding-block: var(--space-md);
    border-bottom: 1px solid var(--border-hairline);
  }

  .log-entry:first-child {
    padding-top: 0;
  }

  .log-entry:last-child {
    border-bottom: none;
  }

  .log-entry-date {
    color: var(--text-mute);
    margin-bottom: var(--space-xs);
  }

  .log-entry-body {
    color: var(--text-secondary);
    max-width: 65ch;
  }

  .log-entry-body :global(p) {
    margin: 0;
  }

  .log-entry-body :global(p + p) {
    margin-top: var(--space-xs);
  }

  .log-entry-body :global(a) {
    color: var(--moonglow);
    text-decoration: underline;
  }
</style>
