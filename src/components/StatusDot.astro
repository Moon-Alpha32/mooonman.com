---
interface Props {
  status: 'live' | 'wip' | 'archived';
}
const { status } = Astro.props;

const labels: Record<Props['status'], string> = {
  live: 'Live',
  wip: 'In progress',
  archived: 'Archived',
};
---

<span class="status">
  <span class={`status-dot status-dot--${status}`} aria-hidden="true"></span>
  <span class="label-mono status-label">{labels[status]}</span>
</span>

<style>
  .status {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .status-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .status-dot--live {
    background: var(--success);
  }

  .status-dot--wip {
    background: var(--warning);
  }

  .status-dot--archived {
    background: var(--text-mute);
  }

  .status-label {
    color: var(--text-mute);
  }
</style>
