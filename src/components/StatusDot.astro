---
interface Props {
  status: 'live' | 'wip' | 'archived';
}
const { status } = Astro.props;

const labels: Record<Props['status'], string> = {
  live: 'Live',
  wip: 'In progress',
  archived: 'Archived',
};
---

<span class={`label-mono status status--${status}`}>{labels[status]}</span>

<style>
  .status {
    display: inline-block;
  }

  .status--live {
    color: var(--spot-red);
  }

  .status--wip {
    color: var(--navy);
  }

  .status--archived {
    color: var(--ink-mute);
  }
</style>
