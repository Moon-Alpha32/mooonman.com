---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Postponed — mooonman"
  description="This page doesn't exist — or hasn't kicked off yet."
  noindex
>
  <section class="container not-found">
    <h1 class="display-lg">Postponed.</h1>
    <p class="body not-found-body">This page doesn't exist — or hasn't kicked off yet.</p>
    <a href="/" class="body-sm back-link">← Back to the programme</a>
  </section>
</BaseLayout>

<style>
  .not-found {
    min-height: 60vh;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: var(--space-sm);
  }

  .not-found-body {
    color: var(--ink-mute);
  }

  .back-link {
    color: var(--navy);
    text-decoration: underline;
  }
</style>
