---
import BaseLayout from '../layouts/BaseLayout.astro';
import Eyebrow from '../components/Eyebrow.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Button from '../components/Button.astro';
import LogEntry from '../components/LogEntry.astro';
import { getCollection } from 'astro:content';
import { getLogEntries } from '../lib/log';
import { getRepoStats } from '../lib/github';

const allProjects = await getCollection('projects', ({ data }) => !data.draft);
const featured = await Promise.all(
  allProjects
    .filter((project) => project.data.featured)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
    .slice(0, 6)
    .map(async (project) => ({ project, stats: await getRepoStats(project.data.repo) }))
);

const recentLogEntries = await getLogEntries({ limit: 3 });
const logCount = (await getCollection('log', ({ data }) => !data.draft)).length;

const liveCount = allProjects.filter((p) => p.data.status === 'live').length;
const wipCount = allProjects.filter((p) => p.data.status === 'wip').length;
const archivedCount = allProjects.filter((p) => p.data.status === 'archived').length;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      name: 'mooonman',
      url: Astro.site?.toString(),
      description:
        'mooonman.com is where I put personal projects, experiments, and ideas — some finished, some in progress, all mine.',
    },
    {
      '@type': 'Person',
      name: 'Alex',
      url: Astro.site?.toString(),
      sameAs: ['https://github.com/Moon-Alpha32'],
    },
  ],
};
---

<BaseLayout
  title="mooonman"
  description="mooonman.com is where I put personal projects, experiments, and ideas — some finished, some in progress, all mine."
  jsonLd={jsonLd}
>
  <section class="hero">
    <div class="container hero-inner">
      <p class="label-mono hero-eyebrow">PERSONAL PROJECTS &amp; IDEAS</p>
      <h1 class="display-xl hero-headline">Building things, one small orbit at a time.</h1>
      <p class="body-lg hero-subline">
        mooonman.com is where I put personal projects, experiments, and ideas — some
        finished, some in progress, all mine.
      </p>
      <Button href="#projects" variant="ghost">View projects ↓</Button>

      <div class="teamsheet label-mono">
        <span>{liveCount} live</span>
        <span>{wipCount} in progress</span>
        <span>{archivedCount} archived</span>
        <span>{logCount} log {logCount === 1 ? 'entry' : 'entries'}</span>
      </div>
    </div>
  </section>

  <section class="container section" id="projects">
    <Eyebrow text="01 — PROJECTS" />
    <h2 class="display-lg section-heading">Selected work</h2>
    <div class="project-grid">
      {
        featured.map(({ project, stats }, i) => (
          <ProjectCard
            href={`/projects/${project.id}/`}
            title={project.data.title}
            description={project.data.description}
            status={project.data.status}
            tags={project.data.tags}
            stats={stats}
            number={i + 1}
          />
        ))
      }
    </div>
    <div class="section-cta">
      <Button href="/projects/" variant="ghost">All projects →</Button>
    </div>
  </section>

  <section class="container section" id="log">
    <Eyebrow text="02 — LOG" />
    <h2 class="display-lg section-heading">Recent activity</h2>
    <div class="log-list">
      {
        recentLogEntries.map(({ entry, Content }) => (
          <LogEntry date={entry.data.date}>
            <Content />
          </LogEntry>
        ))
      }
    </div>
    <div class="section-cta">
      <Button href="/log/" variant="ghost">All entries →</Button>
    </div>
  </section>

  <section class="container section" id="about">
    <Eyebrow text="03 — ABOUT" />
    <h2 class="display-lg section-heading">About</h2>
    <p class="body about-body">
      I'm Alex. This site is where I keep my personal projects — small tools and
      experiments I build in my spare time, mostly around things I already care about,
      like Fantasy Premier League and football stats. Some are finished, some are
      half-built, and that's fine; the point is to keep making things and putting them
      somewhere. mooonman is the home orbit.
    </p>
  </section>
</BaseLayout>

<style>
  .hero {
    min-height: 70vh;
    display: flex;
    align-items: center;
    border-bottom: 3px solid var(--navy);
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-md);
  }

  .hero-eyebrow {
    color: var(--spot-red);
  }

  .hero-subline {
    color: var(--ink-mute);
    max-width: 65ch;
  }

  .teamsheet {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm) var(--space-md);
    color: var(--ink-mute);
    margin-top: var(--space-sm);
    padding-top: var(--space-sm);
    border-top: 1px dashed var(--border-rule);
    width: 100%;
  }

  .section {
    padding-block: var(--space-section);
  }

  .section-heading {
    margin-bottom: var(--space-xl);
  }

  .project-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }

  .section-cta {
    margin-top: var(--space-xl);
  }

  .about-body {
    max-width: 65ch;
  }

  @media (max-width: 768px) {
    .project-grid {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: auto;
      padding-block: var(--space-2xl);
    }
  }
</style>
