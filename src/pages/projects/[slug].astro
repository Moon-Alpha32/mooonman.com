---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Tag from '../../components/Tag.astro';
import StatusDot from '../../components/StatusDot.astro';
import { getCollection, render } from 'astro:content';
import { getRepoStats } from '../../lib/github';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const stats = await getRepoStats(project.data.repo);

const formattedDate = new Intl.DateTimeFormat('en-GB', {
  year: 'numeric',
  month: 'long',
}).format(project.data.date);

const canonicalURL = new URL(`/projects/${project.id}/`, Astro.site);
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: project.data.title,
  description: project.data.description,
  url: canonicalURL.toString(),
  dateCreated: project.data.date.toISOString(),
  author: { '@type': 'Person', name: 'Alex', url: Astro.site?.toString() },
  keywords: project.data.tags.join(', '),
  ...(project.data.url ? { sameAs: project.data.url } : {}),
};
---

<BaseLayout
  title={`${project.data.title} — mooonman`}
  description={project.data.description}
  ogType="article"
  publishedTime={project.data.date}
  jsonLd={jsonLd}
>
  <article class="container section">
    <a href="/projects/" class="body-sm back-link">← All projects</a>

    <div class="title-block">
      <div class="meta-row">
        <StatusDot status={project.data.status} />
        <span class="label-mono meta-date">{formattedDate}</span>
        {stats && <span class="label-mono meta-date">· {stats}</span>}
      </div>
      <h1 class="display-xl project-title">{project.data.title}</h1>
      <div class="tag-row">
        {project.data.tags.map((tag) => <Tag label={tag} />)}
      </div>
    </div>

    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .section {
    padding-block: var(--space-section);
  }

  .back-link {
    display: inline-block;
    color: var(--navy);
    margin-bottom: var(--space-xl);
  }

  .back-link:hover {
    color: var(--spot-red);
  }

  .title-block {
    margin-bottom: var(--space-xl);
  }

  .meta-row {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
  }

  .meta-date {
    color: var(--ink-mute);
  }

  .project-title {
    margin-bottom: var(--space-md);
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .prose {
    max-width: 65ch;
    color: var(--ink-mute);
  }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-weight: 400;
    text-transform: uppercase;
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: 0.005em;
    line-height: 1.05;
    color: var(--ink);
    margin-top: var(--space-xl);
    margin-bottom: var(--space-sm);
  }

  .prose :global(h3) {
    font-family: var(--font-display);
    font-weight: 400;
    text-transform: uppercase;
    font-size: 1.5rem;
    letter-spacing: 0.005em;
    line-height: 1.1;
    color: var(--ink);
    margin-top: var(--space-lg);
    margin-bottom: var(--space-sm);
  }

  .prose :global(p) {
    margin-bottom: var(--space-sm);
  }

  .prose :global(a) {
    color: var(--navy);
    text-decoration: underline;
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    background: var(--surface-raised);
    border: 1px solid var(--border-rule);
    border-radius: var(--radius);
    padding: 2px 6px;
  }

  .prose :global(pre) {
    background: var(--surface-raised);
    border: 1px solid var(--border-rule);
    border-radius: var(--radius);
    padding: var(--space-md);
    overflow-x: auto;
  }

  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
  }
</style>
